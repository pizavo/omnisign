<configuration>
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{YYYY-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
    <logger name="org.eclipse.jetty" level="INFO"/>
    <logger name="io.netty" level="INFO"/>
    <!-- All DSS WARN output is suppressed at the parent level and captured
         programmatically by DssLogCapture during operations. Only ERROR events
         propagate to the root appender. -->
    <logger name="eu.europa.esig" level="ERROR"/>
    <!-- TSL loggers stay at explicit ERROR so DssLogCapture does not lower them
         to WARN during operations (their output is extremely verbose and handled
         through a separate TL-warning mechanism). -->
    <logger name="eu.europa.esig.dss.tsl.runnable" level="ERROR"/>
    <logger name="eu.europa.esig.dss.tsl.function.converter" level="ERROR"/>
    <logger name="eu.europa.esig.dss.tsl.sync" level="ERROR"/>
    <logger name="org.apache.pdfbox.pdfparser" level="ERROR"/>
</configuration>