<configuration>
    <statusListener class="ch.qos.logback.core.status.NopStatusListener"/>
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${omnisign.log.dir}/omnisign.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${omnisign.log.dir}/omnisign.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- All DSS WARN output is suppressed at the parent level and captured
         programmatically by DssLogCapture during operations. Only ERROR events
         propagate to the root appender. -->
    <logger name="eu.europa.esig" level="ERROR"/>
    <!-- TSL loggers stay at explicit ERROR so DssLogCapture does not lower them
         to WARN during operations (their output is extremely verbose and handled
         through a separate TL-warning mechanism). -->
    <logger name="eu.europa.esig.dss.tsl.runnable" level="ERROR"/>
    <logger name="eu.europa.esig.dss.tsl.function.converter" level="ERROR"/>
    <logger name="eu.europa.esig.dss.tsl.sync" level="ERROR"/>
    <logger name="org.apache" level="WARN"/>
    <logger name="org.apache.pdfbox.pdfparser" level="ERROR"/>

    <root level="WARN">
        <appender-ref ref="STDERR"/>
        <appender-ref ref="FILE"/>
    </root>
</configuration>

